{
    "name": "popartdesign/joomla-shortcoder",
    "description": "A lightweight, template-based shortcode engine for Joomla.",
    "homepage": "https://github.com/PopArtDesign/joomla-shortcoder",
    "type": "joomla-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Oleg Voronkovich",
            "email": "oleg-voronkovich@yandex.ru",
            "homepage": "https://github.com/voronkovich"
        }
    ],
    "autoload": {
        "psr-4": {
            "PopArtDesign\\JoomlaShortcoder\\Plugin\\Content\\Shortcoder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PopArtDesign\\JoomlaShortcoder\\Plugin\\Content\\Shortcoder\\Test\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs": "php-cs-fixer fix -v --dry-run --allow-risky=yes",
        "cs-fix": "php-cs-fixer fix -v --allow-risky=yes"
    }
}
